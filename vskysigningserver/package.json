    "pretest": "pnpm run compile",
    "posttest": "pnpm run lint",
    "test": "jest"
  },
  "dependencies": {
    "@types/bn.js": "5.1.1",
    "axios": "1.16.0",
    "base64url": "https://github.com/VerusCoin/base64url.git",
    "bn.js": "5.2.1",
    "cors": "2.8.5",
    "crypto-browserify": "3.12.1",
    "dotenv": "16.4.5",
    "express": "5.1.0",
    "verus-typescript-primitives": "git+https://github.com/VerusCoin/verus-typescript-primitives",
    "verusd-rpc-ts-client": "git+https://github.com/VerusCoin/verusd-rpc-ts-client",
    "verusid-ts-client": "git+https://github.com/VerusCoin/verusid-ts-client"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.6",
    "@types/node": "24.12.2",
    "jest": "29.7.0",
    "tsx": "4.19.0",
    "typescript": "5.7.3"
  }
}
