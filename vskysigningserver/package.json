{
  "name": "vskysigningserver",
  "version": "0.2.0",
  "imports": {
    "#/*": "./src/*"
  },
  "bin": {
    "vsky-signing-server": "bin/vsky-signing-server.js"
  },
  "scripts": {
    "dev": "tsx --watch src/local_server.ts",
    "start": "NODE_ENV=production tsx --watch src/local_server.ts",
